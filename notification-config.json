{
    "LambdaFunctionConfigurations": [
        {
            "Id": "data-processing-notification",
            "LambdaFunctionArn": "arn:aws:lambda:eu-north-1:424999960734:function:data-processor-rgq8r0",
            "Events": [
                "s3:ObjectCreated:*"
            ],
            "Filter": {
                "Key": {
                    "FilterRules": [
                        {
                            "Name": "prefix",
                            "Value": "data/"
                        }
                    ]
                }
            }
        }
    ]
}
